# Nordea Open Banking — sandbox credentials (from My apps in the developer portal)
CLIENT_ID=
CLIENT_SECRET=

# Must match the redirect URL you registered on the app (the article uses this exact one)
REDIRECT_URI=https://example.com/callback

# Sandbox test account country: NO | SE | FI | DK
COUNTRY=NO

# Sandbox mock PSU id (find valid test ids in the portal's sandbox docs). Leave blank to try without.
SANDBOX_AUTHORIZER_ID=

# --- advanced overrides (only touch if a path 404s) ---
# NORDEA_BASE=https://api.nordeaopenbanking.com
# AUTH_PREFIX=/business/v5
# AIS_PREFIX=/business/v4
# SCOPE=ACCOUNTS_BASIC,ACCOUNTS_BALANCES,ACCOUNTS_DETAILS,ACCOUNTS_TRANSACTIONS
